{
  "name": "advancedideasmechanics/mezzio-ga-measurement-protocol",
  "description": "Mezzio Middleware for Google Analytics Measurement Protocol",
  "type": "library",
  "minimum-stability": "stable",
  "license": "MIT",
  "keywords": [
    "matthewpallotta",
    "advancedideasmechanics",
    "mezzio",
    "php",
    "library",
    "google",
    "analytics"
  ],
  "authors": [
