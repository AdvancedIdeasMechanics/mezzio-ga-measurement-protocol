  },
  "homepage": "https://advanced.im/product/mezzio-ga-measurement-protocol",
  "require": {
    "php": "~8.1.0 || ~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
    "psr/http-server-middleware": "^1.0",
    "mezzio/mezzio-template": "^2.0 || ^3.0",
